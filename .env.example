# ===========================
# BOT CONFIGURATION
# ===========================
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
BOT_USERNAME=MEX_Tracker_Bot
ADMIN_ID=YOUR_TELEGRAM_ADMIN_ID
ALERT_CHANNEL_ID=YOUR_TELEGRAM_ALERT_CHANNEL_ID # Example: -1001234567890

# ===========================
# MULTI-CHAIN RPC (MAINNET)
# ===========================
ETH_RPC=YOUR_INFURA_OR_ALCHEMY_RPC_URL # e.g., https://mainnet.infura.io/v3/YOUR_PROJECT_ID
SOLANA_RPC=YOUR_HELIUS_OR_QUICKNODE_RPC_URL # e.g., https://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY
# BSC_RPC=https://bsc-dataseed.binance.org # Uncomment to enable BNB chain

# ===========================
# PROJECT WALLET ADDRESSES (These are owner wallets, distinct from user wallets)
# These are used by the bot for its own operations, not user tracking.
# ===========================
OWNER_WALLET_ETH=YOUR_PROJECT_ETH_WALLET_ADDRESS
OWNER_WALLET_SOL=YOUR_PROJECT_SOL_WALLET_ADDRESS
OWNER_WALLET_BTC=YOUR_PROJECT_BTC_WALLET_ADDRESS
# OWNER_WALLET_BNB=YOUR_PROJECT_BNB_WALLET_ADDRESS # Uncomment to enable BNB chain

# ===========================
# API KEYS (OPTIONAL, for enhanced data/scans)
# ===========================
ETHERSCAN_API=YOUR_ETHERSCAN_API_KEY
SOLSCAN_API=YOUR_SOLSCAN_API_KEY
# BSCSCAN_API=YOUR_BSCSCAN_API_KEY # Uncomment to enable BNB chain

# ===========================
# PAYMENTS (CRYPTO ONLY) - For future subscription model
# ===========================
ENABLE_SUBSCRIPTIONS=true
PAYMENT_METHOD=CRYPTO

# ===========================
# DATABASE CONFIGURATION
# For local development, sqlite:///./sql_app.db will be used by default.
# For production, you should use a PostgreSQL/MySQL database URL.
# Example for PostgreSQL:
# DATABASE_URL=postgresql://user:password@host:port/dbname
